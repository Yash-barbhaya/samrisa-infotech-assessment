{
  "openapi": "3.0.1",
  "info": {
    "title": "SamrisaBackend",
    "version": "1.0"
  },
  "paths": {
    "/api/Billing/checkout": {
      "post": {
        "tags": [
          "Billing"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillingSubmissionDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BillingSubmissionDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BillingSubmissionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BillingSubmissionDto": {
        "required": [
          "address",
          "email",
          "fullName",
          "paymentMethod"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "address": {
            "minLength": 1,
            "type": "string"
          },
          "paymentMethod": {
            "minLength": 1,
            "type": "string"
          },
          "totalAmount": {
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    }
  }
}